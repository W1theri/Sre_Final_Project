{
  "title": "E-Commerce SRE Dashboard",
  "uid": "ecommerce-sre",
  "tags": ["sre", "ecommerce"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Service Availability (SLO: 99.9%)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "((1 - (sum(rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval])))) * 100) or vector(100)",
        "legendFormat": "Availability %",
        "datasource": "Prometheus"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.9}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval]))",
        "legendFormat": "RPS",
        "datasource": "Prometheus"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Error Rate (SLO: < 1%)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "((sum(rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval]))) * 100) or vector(0)",
        "legendFormat": "Error %",
        "datasource": "Prometheus"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Active Cart Sessions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "sum(active_users_total{job=\"ecommerce-app\"})",
        "legendFormat": "Sessions",
        "datasource": "Prometheus"
      }],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "sum by (endpoint) (rate(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval]))",
        "legendFormat": "{{endpoint}}",
        "datasource": "Prometheus"
      }],
      "options": {
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 6,
      "title": "Latency Percentiles (SLO: p99 < 500ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 7,
      "title": "Orders: Success vs Failed",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "rate(orders_total{status=\"success\"}[5m])",
          "legendFormat": "Success",
          "datasource": "Prometheus"
        },
        {
          "expr": "rate(orders_total{status=\"failed\"}[5m])",
          "legendFormat": "Failed",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "expr": "sum by (status) (increase(http_requests_total{job=\"ecommerce-app\", endpoint!~\"/metrics|/health\"}[$__range]))",
        "legendFormat": "HTTP {{status}}",
        "datasource": "Prometheus"
      }]
    }
  ],
  "time": {"from": "now-1h", "to": "now"}
}
